# Adobe Analytics OAuth Server-to-Server credentials
# These MUST only live on the backend proxy — never in the React bundle.
ADOBE_CLIENT_ID=
ADOBE_CLIENT_SECRET=
ADOBE_ORG_ID=
ADOBE_IMS_ORG_ID=
ADOBE_REPORT_SUITE_ID=
ADOBE_GLOBAL_COMPANY_ID=

# Backend proxy base URL that the React app talks to
REACT_APP_API_BASE_URL=http://localhost:4000
